# --- Indexer REST API (reads) ---
VITE_API_URL=http://localhost:8787

# --- Contract addresses (writes). From the deploy / forge script output. ---
# If unset or invalid, the app shows a "set addresses" gate.
VITE_WORD_REGISTRY=0x...
VITE_DEED_MARKETPLACE=0x...

# --- Chain selection ---
# Leave unset for Base Sepolia (prod). Set to 1 to use the local anvil chain (id 31337).
# VITE_USE_ANVIL=1
VITE_ANVIL_RPC=http://localhost:8545
VITE_BASE_SEPOLIA_RPC=https://sepolia.base.org

# --- WalletConnect (optional). HUMAN TASK: create a project id at cloud.walletconnect.com ---
# When empty, only the injected (browser wallet) connector is used.
VITE_WALLETCONNECT_PROJECT_ID=

# --- Privy (sign-in modal). HUMAN TASK: create an app at dashboard.privy.io ---
# Public client id (safe to ship). When set, sign-in uses the Privy modal
# (email / Google / X + an embedded wallet for users without one) and Privy manages
# wagmi's connectors. When empty, the app falls back to the injected-only wallet stack.
# Configure login methods + allowed origins (your domain + http://localhost:5173) in
# the Privy dashboard.
VITE_PRIVY_APP_ID=
