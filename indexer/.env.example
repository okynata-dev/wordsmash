# Indexer configuration. In production these live in wrangler.toml [vars] (and
# secrets via `wrangler secret put`). This file documents what each var means.

# JSON-RPC endpoint for the chain you are indexing.
RPC_URL=http://127.0.0.1:8545

# WordRegistry contract address (ERC721 + WordClaimed events).
REGISTRY=0x0000000000000000000000000000000000000000

# DeedMarketplace contract address (Listed/Cancelled/Sale events).
MARKETPLACE=0x0000000000000000000000000000000000000000

# Block at which the contracts were deployed (start of indexing).
START_BLOCK=0

# Base URL of the web app; /share/:word redirects crawlers-then-humans here.
WEB_APP_BASE=http://localhost:5173
